{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/japanese.js": {
      "maxDuration": 30
    },
    "api/tts.js": {
      "maxDuration": 15
    },
    "api/translate.js": {
      "maxDuration": 30
    },
    "api/example.js": {
      "maxDuration": 25
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    }
  ]
}
